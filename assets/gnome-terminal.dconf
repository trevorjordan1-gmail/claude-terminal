# GNOME Terminal preferences, dumped from the reference machine.
# Loaded by modules/core/42-terminal-prefs.sh into /org/gnome/terminal/legacy/
# ONLY when that tree is still untouched (fresh box). Apply manually with:
#   dconf load /org/gnome/terminal/legacy/ < assets/gnome-terminal.dconf
# The profile UUID below is GNOME Terminal's well-known default profile id.

[keybindings]
copy='<Primary>c'
new-window='<Primary>n'
paste='<Primary>v'

[profiles:/:b1dcc9dd-5262-4d8d-a863-c897e6d979b9]
background-color='rgb(46,52,54)'
bold-is-bright=true
default-size-columns=200
default-size-rows=50
foreground-color='rgb(211,215,207)'
use-theme-colors=true
use-theme-transparency=true
